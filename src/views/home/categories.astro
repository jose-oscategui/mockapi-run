---
import { endpoints } from '@/data/endpoints/registry';


---
<section class='section' id='categories' data-od-id='categories'>
  <div class='container'>
    <p class='eyebrow'>API Resources</p>
    <h2>Available Categories</h2>
    <p class='lead'>Select a category to view endpoints and sample responses.</p>

    <div class='grid-categories'>
      {endpoints.map((endpoint) => (
        <a href={`/docs#${endpoint.id}`} class='category-card'>
          <h3>{endpoint.title}</h3>
          <p>{endpoint.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .grid-categories {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .category-card {
    background: var(--bg);
    padding: 32px 24px;
    transition: 0.2s;
    cursor: pointer;
    text-align: left;
  }
  .category-card:hover {
    background: var(--surface);
  }
  .category-card h3 {
    font-size: 16px;
    margin-bottom: 8px;
  }
  .category-card p {
    font-size: 14px;
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
  }
</style>
