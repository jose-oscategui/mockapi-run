---
import type { Endpoint } from '@/types/endpoint.type';

const { method, path, description, exampleTitle, response, id } = Astro.props as Endpoint;
const endpointUrl = `/api${path}`;
---

<div class='endpoint-card' id={id}>
  <div class='endpoint-header'>
    <span class='method'>{method}</span>
    <span class='path'>{path}</span>
    <a
      class='endpoint-link'
      href={endpointUrl}
      target='_blank'
      rel='noreferrer'
      aria-label={`Open endpoint ${endpointUrl}`}
    >
      Open endpoint
    </a>
  </div>
  <div class='endpoint-body'>
    <div class='endpoint-desc'>{description}</div>
    <div class='code-block'>
      <div class='code-header'>{exampleTitle}</div>
      <pre style='margin: 0;' set:html={JSON.stringify(response, null, 2)} />
    </div>
  </div>
</div>

<style>
  .endpoint-card {
    scroll-margin-top: 80px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 32px;
    overflow: hidden;
  }
  .endpoint-header {
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 14px;
  }
  .method {
    background: var(--accent-soft);
    color: var(--accent);
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 700;
    font-size: 11px;
  }
  .path {
    font-weight: 500;
  }
  .endpoint-link {
    margin-left: auto;
    min-width: 24px;
    min-height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 10px;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 12px;
    line-height: 1;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .endpoint-link:hover {
    color: var(--fg);
    border-color: color-mix(in oklch, var(--accent) 35%, var(--border));
    background: color-mix(in oklch, var(--accent) 10%, transparent);
  }
  .endpoint-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .endpoint-body {
    padding: 20px;
  }
  .endpoint-desc {
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 16px;
  }
</style>
